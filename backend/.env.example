# Backend environment configuration (example)
# Copy this file to `.env` and fill in values for your machine.
#
# Do NOT commit your real `.env` file.

# ----------------------------
# App
# ----------------------------
APP_NAME=SLTM Backend
APP_ENV=development
DEBUG=true

# Where the API server listens
HOST=0.0.0.0
PORT=8000

# Allowed CORS origins (comma-separated)
# Vite default is http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----------------------------
# Database
# ----------------------------
# For local development you can use SQLite:
# DATABASE_URL=sqlite:///./sltm.db
#
# Or PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sltm
DATABASE_URL=sqlite:///./sltm.db

# ----------------------------
# Security / Auth (optional for MVP)
# ----------------------------
# Set a strong secret in production
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----------------------------
# External services (optional / future)
# ----------------------------
# If you later integrate third-party APIs, add keys here.
# TRAIN_API_BASE_URL=
# TRAIN_API_KEY=

# If you later add web scraping, keep user-agent configurable.
SCRAPER_USER_AGENT=SLTM-Backend/1.0 (+https://github.com/<OWNER>/<REPO>)
